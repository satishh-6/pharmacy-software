{
  "name": "medxpert-pharmacy",
  "version": "1.0.0",
  "description": "MedXpert Pharmacy Management System",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "electron": "node_modules\\.bin\\electron.cmd .",
    "build-win": "node_modules\\.bin\\electron-builder.cmd --win",
    "build-mac": "node_modules\\.bin\\electron-builder.cmd --mac"
  },
  "build": {
    "appId": "com.medxpert.pharmacy",
    "productName": "MedXpert Pharmacy",
    "copyright": "Copyright 2024 MedXpert",
    "icon": "assets/icon",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MedXpert Pharmacy"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "electron-icon-builder": "^2.0.1",
    "png-to-ico": "^3.0.1"
  }
}
